#!/usr/bin/env bash

# A pre-commit hook for SageMath
#
# Consider activating it so that your code is automatically checked before each
# commit:
#
#   $ git config core.hooksPath git-hooks

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Text formatting
RED='\e[1;31m'
BLUE='\e[1;34m'
YLLW='\e[1;33m'
NRM='\e[0m'  # normal

tool_display() {
  case "$1" in
    autopep8)     printf "${BLUE}auto${YLLW}pep8${NRM}" ;;
    ruff)         printf "${YLLW}ruff${NRM}" ;;
    clang-format) printf "${BLUE}clang-format${NRM}" ;;
  esac
}

# Redirect stdout/stderr to /dev/null if not verbose
out() {
  if [ "$verbose" = true ]; then
    printf "\n"
    "$@"
  else
    "$@" > /dev/null 2>&1
  fi
}

# ---------------------------------------------------------------------------
# Init
# ---------------------------------------------------------------------------

init_file_lists() {
  python_files=$(git diff --staged --name-only | grep "\.py$\|\.pyi$")
  cython_files=$(git diff --staged --name-only | grep "\.pyx$\|\.pxd$\|\.pxi$")
  c_files=$(git diff --staged --name-only | grep "\.c$\|\.cpp$\|\.h$")
  [ -z "$python_files" ] && [ -z "$cython_files" ] && [ -z "$c_files" ] && exit 0
}

init_check_tools() {
  _check_tool() {
    command -v "$1" > /dev/null && return 0
    if [ "$mode" == "check-only" ]; then
      local name=$(tool_display "$1")
      printf "${YLLW}Warning${NRM}: $name not found; skipping related checks.\n"
    fi
    return 1
  }

  autopep8_flag=false
  ruff_flag=false
  clang_format_flag=false

  if [ -n "$python_files" ] || [ -n "$cython_files" ]; then
    _check_tool autopep8 && autopep8_flag=true
  fi
  [ -n "$python_files" ] && _check_tool ruff         && ruff_flag=true
  [ -n "$c_files" ]      && _check_tool clang-format && clang_format_flag=true
}

init_flags() {
  # Set formatter flags
  autopep8_flags="-j0 --exit-code"
  ruff_flags="check --config .github/workflows/ruff.toml --preview"
  clang_format_flags="--Werror"

  if [ "$mode" == "check-only" ]; then
    autopep8_flags="--diff $autopep8_flags"
    clang_format_flags="--dry-run $clang_format_flags"
  elif [ "$mode" == "in-place" ]; then
    autopep8_flags="--in-place $autopep8_flags"
    clang_format_flags="-i $clang_format_flags"
  fi

  # Set PEP8 issues to fix (autopep8 by default ignores E226,E24,W50,W690).
  # Ignore E203 to avoid the enforcing of questionable formatting of slices
  # (e.g., [start: end: step]).
  # For Python files, include E226 to add whitespace around operator (e.g., 2*3).
  # For Cython files we are less aggressive in order to avoid adding whitespace
  # around pointers (e.g., `cdef int *array`), casting syntax (e.g., `<int *>`),
  # and keywords (e.g., `except?`).
  python_flags="--ignore=E203,E24,W50,W690"
  cython_flags="--ignore=E203,E211,E225,E226,E227,E228,E24,E275,W50,W690"
}

# ---------------------------------------------------------------------------
# Check-only
# ---------------------------------------------------------------------------

check_autopep8() {
  [ "$autopep8_flag" = false ] && return 0
  printf "$(tool_display autopep8): Checking code formatting..."
  local failed=false
  if [ -n "$python_files" ] && ! out autopep8 $autopep8_flags $python_flags $python_files; then
    failed=true
  fi
  if [ -n "$cython_files" ] && ! out autopep8 $autopep8_flags $cython_flags $cython_files; then
    failed=true
  fi
  $failed && printf " failure.\n" && return 1
  printf " success.\n"
}

check_ruff() {
  [ "$ruff_flag" = false ] && return 0
  printf "$(tool_display ruff): Checking code formatting..."
  if ! out ruff $ruff_flags $python_files; then
    printf " failure.\n" && return 1
  fi
  printf " success.\n"
}

check_clang_format() {
  [ "$clang_format_flag" = false ] && return 0
  printf "$(tool_display clang-format): Checking code formatting..."
  if ! out clang-format $clang_format_flags $c_files; then
    printf " failure.\n" && return 1
  fi
  printf " success.\n"
}

# ---------------------------------------------------------------------------
# Format in-place
# ---------------------------------------------------------------------------

format_autopep8() {
  [ "$autopep8_flag" = false ] && return 0
  printf "$(tool_display autopep8): Auto-formatting..."
  local changed=false
  [ -n "$python_files" ] && ! autopep8 $autopep8_flags $python_flags $python_files && changed=true
  [ -n "$cython_files" ] && ! autopep8 $autopep8_flags $cython_flags $cython_files && changed=true
  if $changed; then
    printf " check the unstaged changes.\n" && return 1
  fi
  printf " no changes required.\n"
}

format_ruff() {
  [ "$ruff_flag" = false ] && return 0
  printf "$(tool_display ruff): Auto-formatting..."
  if ! ruff $ruff_flags $python_files > /dev/null; then
    ruff $ruff_flags -q --fix $python_files
    printf " check the unstaged changes.\n" && return 1
  fi
  printf " no changes required.\n"
}

format_clang_format() {
  [ "$clang_format_flag" = false ] && return 0
  printf "$(tool_display clang-format): Auto-formatting..."
  if ! clang-format --dry-run --Werror $c_files 2> /dev/null; then
    clang-format $clang_format_flags $c_files
    printf " check the unstaged changes.\n" && return 1
  fi
  printf " no changes required.\n"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

mode="check-only"
verbose=false

for arg in "$@"; do
  case "$arg" in
    in-place) mode="in-place" ;;
    verbose)  verbose=true ;;
    *)
      printf "${RED}Error${NRM}: Unknown argument: $arg\n"
      exit 1
      ;;
  esac
done

init_file_lists
init_check_tools
init_flags

changes=false
if [ "$mode" == "check-only" ]; then
  check_autopep8     || changes=true
  check_ruff         || changes=true
  check_clang_format || changes=true
  if $changes; then
    printf "${RED}Error${NRM}: Ill-formatted files staged for commit.\n\
To view the issues, use 'git hook run pre-commit -- verbose'.\n\
To auto-format the files, use 'git hook run pre-commit -- in-place'.\n\
To avoid these pre-commit checks, use 'git commit --no-verify'.\n"
    exit 1
  fi
elif [ "$mode" == "in-place" ]; then
  format_autopep8
  format_ruff
  format_clang_format
fi
